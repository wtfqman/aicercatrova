BOT_TOKEN=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_VIDEO_MODEL=openai/gpt-4o-mini
OPENROUTER_TRANSCRIBE_MODEL=openai/whisper-large-v3
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=Cerca Trova Creator Bot
OPENROUTER_APP_URL=https://example.com
AI_TIMEOUT_MS=45000
HISTORY_LIMIT=4
USE_HISTORY=false

# Optional: Grok/xAI for video-link processing, not for normal bot answers.
XAI_API_KEY=
XAI_MODEL=grok-4.3
XAI_BASE_URL=https://api.x.ai/v1

# Optional fallback/replacement for OpenRouter/xAI video processing.
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
# auto tries OpenRouter first, then OpenAI, then xAI.
VIDEO_AI_PROVIDER=auto

VIDEO_MAX_DURATION_SEC=600
VIDEO_JOB_TIMEOUT_MS=300000
TELEGRAM_HANDLER_TIMEOUT_MS=420000
YT_DLP_FORMAT=ba/b[height<=720]/worst
YT_DLP_FORCE_IP=auto
YT_DLP_SOCKET_TIMEOUT_SEC=60
YT_DLP_RETRIES=3
YT_DLP_EXTRACTOR_RETRIES=3
# Optional: if TikTok is blocked by DNS/provider, put proxy here.
# Example: http://127.0.0.1:7890 or socks5://127.0.0.1:1080
YT_DLP_PROXY=
TIKTOK_APP_INFO=7355728856979392262
TIKTOK_API_HOSTNAME=api16-normal-c-useast1a.tiktokv.com
# Set true only if you use proxy/VPN and want yt-dlp to retry TikTok after the built-in fallback.
TIKTOK_TRY_YT_DLP_FALLBACK=false

# Optional: Instagram often requires authenticated cookies for Reels downloads.
# Prefer a cookies.txt file on production servers.
YT_DLP_COOKIES_FILE=
# Local desktop alternative, for example: chrome, edge, firefox
YT_DLP_COOKIES_FROM_BROWSER=
